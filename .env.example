# Скопируйте в .env и заполните. НЕ коммитьте .env (chmod 600).
# Пока BOT_TOKEN пуст — бот работает только в симуляции (run_simulate.py), не в бою.

BOT_TOKEN=                 # токен бота из @BotFather (обязателен для боевого режима)
OPERATOR_CHAT_ID=          # ваш числовой Telegram id — туда придут алерты о горячих лидах

# --- необязательные переопределения (по умолчанию и так ок) ---
# TAROT_CODE_WORD=ТАРО
# TAROT_JITTER=0           # 1 = включить случайный разброс задержек (анти-бан)
# TAROT_DB=/opt/tarot-bot/data/tarot.sqlite
# TAROT_MEDIA=/opt/tarot-bot/media
# TAROT_XLSX=/opt/tarot-bot/Воронка таро.xlsx
